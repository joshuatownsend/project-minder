{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Minder Tray",
  "version": "0.1.0",
  "identifier": "com.minder.tray",
  "build": {
    "frontendDist": "./frontend"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
