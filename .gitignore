# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*

# env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# persistent cache
.cache/

# project minder config (user-specific)
.minder.json
# MANUAL_STEPS.md is intentionally NOT ignored — see "Tracking in Git"
# on the Setup page. Append-only checklist of pending dev work; commit
# it like TODO.md and INSIGHTS.md.

# claude code
.claude/
.mcp.json
CLAUDE_MD_SNIPPET.md

# scratch files
manual-steps-tracker.html
capture-new.mjs
nul

# local research / design references
agentlytics-repo/
.design-fetch/

# codegraph knowledge graph (generated; rebuilt by `codegraph init`)
.codegraph/

# playwright debug logs
.playwright-mcp/

# screenshot captures + ui/ux review artifacts
screenshots/
# …except the published gh-pages site screenshots, which are committed.
!site/screenshots/
!site/screenshots/**
# local preview artifacts from scripts/preview-landing.mjs — not committed
scripts/preview/
uiux-review/

# perf artifacts (large binary captures - kept locally, not committed)
docs/perf/*.heapsnapshot
docs/perf/trace-*.json
docs/perf/report.html
docs/perf/report.json

# git worktrees
.worktrees/

# tauri tray app — rust build artifacts (rebuilt by `cargo`/`tauri build`)
src-tauri/target/
src-tauri/gen/

# worker bundle (built fresh by predev/prebuild via scripts/build-worker.mjs)
workers/dist/

# bundled MCP server artifact (built fresh via scripts/build-mcp-screenshot.mjs;
# users run `npm run build:mcp-screenshot` once before `claude mcp add`)
dist/

# local agent/lint caches + throwaway session screenshots (not committed)
.agents/
.claudelint-cache/
/t2.1-*.png
